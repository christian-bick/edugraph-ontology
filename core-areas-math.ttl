@prefix : <http://edugraph.io/edu/>.
@prefix edu: <http://edugraph.io/edu#>.
@prefix owl: <http://www.w3.org/2002/07/owl#>.
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>.
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.
@prefix xml: <http://www.w3.org/XML/1998/namespace>.
@prefix xsd: <http://www.w3.org/2001/XMLSchema#>.

<http://edugraph.io/edu/> a owl:Ontology;
    owl:imports <http://edugraph.io/edu#>.
:Addition a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "Adding numbers together.";
    edu:expands :Sum;
    edu:partOf :NumberOperations.
:Algebra a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "The branch of mathematics that generalizes arithmetics and where letters represent unknown numbers, allowing us to explore patterns, solve equations, and model real-world situations.".
:Analysis a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "The branch of mathematics that deals with continuous change and investigates concepts like limits, continuity, derivatives, integrals, and infinite series to study functions, their properties, and their behavior.".
:Arithmetic a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "The branch of mathematics that deals with the properties and manipulation of numbers, including addition, subtraction, multiplication and division.".
:BaseOperations a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "Base operations are the fundamental arithmetic actions performed on numbers that all other arithmetic operations are based one.";
    edu:partOf :NumberSense.
:Calculus a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "The branch of mathematics that provides tools for analyzing rates of change and accumulation. It deals with instantaneous rates of change that affect the slopes of curves, as well as with accumulation that affects areas under curves.".
:CircularShapeDrawing a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "Circular shape drawing is the ability to create drawings or models of circular shapes.";
    edu:partOf :SpatialModelling.
:ComputationalMathematics a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "The branch of mathematics that involves the development and application of mathematical methods and algorithms for solving problems using computers.".
:DecimalNotation a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "The system of symbols used to represent decimals, including the floating point and its meaning.";
    edu:expands :IntegerNotation;
    edu:partOf :DecimalNumbers.
:DecimalNumbers a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "The representation of rational numbers using a base-10 positional notation system, where a decimal point separates the integer component from a fractional component expressed as a sum of negative powers of ten.";
    edu:constrains :FractionNumbers;
    edu:integrates :DecimalNotation;
    edu:partOf :RationalNumbers.
:Decrement a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "Reducing a quantity by a specific amount.";
    edu:inverts :Increment;
    edu:partOf :BaseOperations.
:Difference a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "Determining the difference in quantities of mathematical object, including numbers where difference represents the amount by which one quantity is greater or less than another.";
    edu:expands :Decrement;
    edu:inverts :Sum;
    edu:partOf :BaseOperations.
:DigitNotation a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "Digit notation uses symbols from 0 to 9 to represent any number.";
    edu:partOf :NumberNotation.
:Division a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "Dividing one number by another.";
    edu:inverts :Multiplication;
    edu:partOf :NumberOperations.
:EllipticShapeDrawing a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "Elliptical shape drawing is the ability to create drawings or models of elliptical shapes.";
    edu:partOf :SpatialModelling.
:Exponentiation a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "Raising a number to a power, meaning multiplying it by itself a certain number of times.";
    edu:expands :Multiplication;
    edu:partOf :NumberOperations.
:FractionNotation a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "The system of symbols used to represent fractions, including the numerator and denominator.";
    edu:integrates :Division, :IntegerNotation;
    edu:partOf :FractionNumbers.
:FractionNumbers a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "The representation of rational numbers as a ratio of two integers, expressed in the form a/b, where the numerator (a) indicates a number of equal parts and the denominator (b) indicates how many of those parts make up a unit or whole.";
    edu:expands :IntegerNumbers, :ProportionInteraction;
    edu:integrates :FractionNotation;
    edu:partOf :RationalNumbers.
:FractionSimplification a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "Reducing a fraction to its simplest form by dividing the numerator and denominator by their greatest common factor.\n\nExample: 12/18 simplifies to 2/3 by dividing both by 6";
    edu:decomposes :FractionNumbers;
    edu:integrates :RatioEquivalence;
    edu:partOf :FractionNumbers.
:Geometry a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "The branch of mathematics that studies shapes, the sizes, positions, and dimensions of things. It explores properties of points, lines, planes, and solids.".
:Increment a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "Raising a quantity by a certain amount.";
    edu:partOf :BaseOperations.
:IntegerMultiplication a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "Multiplying two or integers numbers.\n\nExample: 4 * 3 = 12";
    edu:partOf :Multiplication.
:IntegerSubtraction a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "Finding the difference between two integers.\n\nExample: 10 - 6 = 4";
    edu:partOf :Subtraction.
:IntegerAddition a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "Adding integers together. Example: 5 + 3 = 8";
    edu:partOf :Addition.
:IntegerDivision a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "Dividing one integer by another, which may result in a quotient and a remainder.\n\nExample: 17 / 5 = 3 remainder 2";
    edu:partOf :Division.
:IntegerExponentiation a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "Raising an integer to a power, meaning multiplying it by itself a certain number of times. Example: 2 ^ 4 = 2 * 2 * 2 * 2 = 16";
    edu:partOf :Exponentiation.
:IntegerNotation a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "Applying the system of symbols used to represent integers.\n\nExample: Using the symbols -3, 0, and 12 to represent integers.";
    edu:expands :DigitNotation;
    edu:partOf :IntegerNumbers.
:IntegerNumbers a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "The understanding and application of whole numbers, their additive inverses (negative numbers), and zero, representing discrete values that do not contain fractional or decimal components.";
    edu:integrates :IntegerNotation;
    edu:partOf :NumberSystems.
:IntegerRegrouping a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "Also referred to as carrying or borrowing. The process of exchanging values between place value positions to facilitate arithmetic operations such as addition and subtraction within the set of integer numbers.";
    edu:decomposes :IntegerNumbers;
    edu:partOf :IntegerNumbers.
:IntervalsWithInfinity a owl:NamedIndividual, edu:Area;
    edu:partOf :NumerationWithIntervals.
:IntuitiveMathematics a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "The branch of mathematics that focuses on understanding foundational math concepts through direct experience and visualization, gradually familiarizing students with increasingly formal and abstract representations of math concepts.".
:IrrationalNumbers a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "The understanding and application of real numbers that cannot be expressed as a quotient or fraction of two integers, characterized by decimal representations that are non-terminating and non-repeating.";
    edu:expands :RationalNumbers;
    edu:partOf :NumberSystems.
:LinearShapeDrawing a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "Linear shape drawing is the ability to create drawings or models of shapes with straight sides.";
    edu:partOf :SpatialModelling.
:Logarithm a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "Finding the exponent to which a base must be raised to produce a given number.";
    edu:inverts :Exponentiation;
    edu:partOf :NumberOperations.
:Logic a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "The branch of mathematics that studies reasoning and valid arguments. It provides a framework for determining whether something is true or false based on given premises. It is the foundation for constructing proofs, ensuring that conclusions follow logically from their premises.".
:LowestCommonDenominator a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "Finding the smallest common multiple of the denominators of two or more fractions.\n\nExample: The lowest common denominator of 1/4 and 1/6 is 12.";
    edu:decomposes :FractionNumbers;
    edu:expands :RatioEquivalence;
    edu:partOf :FractionNumbers.
:Measurement a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "Measurement is the process of assigning numbers to describe the properties of objects, such as length, weight, or volume.";
    edu:partOf :SpatialSense.
:MeasuringObjects a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "Measuring objects involves determining their physical dimensions using appropriate tools and units.";
    edu:partOf :Measurement.
:MeasuringTime a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "Measuring time involves quantifying the duration of events or the intervals between them.";
    edu:partOf :Measurement.
:Multiplication a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "Multiplying two or multiple numbers.";
    edu:expands :Addition;
    edu:partOf :NumberOperations.
:NumberNotation a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "Number notation is the system of symbols and rules used to express numerical values.";
    edu:partOf :NumberSense.
:NumberOperations a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "The systematic application of mathematical rules and procedures to combine, transform, or calculate values through fundamental actions such as addition, subtraction, multiplication, and division.";
    edu:partOf :Arithmetic.
:NumberSense a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "Number sense is the intuitive understanding of numbers, their magnitudes, and how they relate to each other.";
    edu:partOf :IntuitiveMathematics.
:NumberSystems a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "The classification, representation, and properties of different sets of numbers such as integers, fractions, decimals including the symbolic frameworks used to express numerical values and their relationships.";
    edu:partOf :Arithmetic.
:NumberTheory a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "The branch of mathematics that studies the properties of numbers, particularly integers (whole numbers). It explores things like prime numbers, divisibility, and number patterns.".
:Numeration a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "Numeration encompasses counting, ordering, and grouping numbers.";
    edu:partOf :NumberSense.
:NumerationWithFractions a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "Numeration with fractions encompasses understanding the density of fraction numbers on the number line.";
    edu:decomposes :FractionNumbers;
    edu:partOf :Numeration.
:NumerationWithIntegers a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "Numeration with numerals includes understanding the sequence and magnitude of whole numbers.";
    edu:decomposes :IntegerNumbers;
    edu:expands :NumericOrder;
    edu:partOf :Numeration.
:NumerationWithIntervals a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "Numeration with intervals is used to represent sets of numbers with specific limits.";
    edu:partOf :Numeration.
:NumericComparison a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "Numeric comparison involves evaluating whether one number is greater than, less than, or equal to another.";
    edu:partOf :NumberSense.
:NumericIdentity a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "Numeric identity refers to the understanding that a number remains the same regardless of its representation.";
    edu:partOf :NumericComparison.
:NumericOrder a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "Numeric order refers to the arrangement of numbers in ascending or descending sequence based on their magnitude.";
    edu:integrates :NumericIdentity;
    edu:partOf :NumericComparison.
:ProportionAbstraction a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "Proportion abstraction is the ability to generalize proportional relationships and apply them to new situations.";
    edu:partOf :ProportionSense.
:ProportionExpression a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "Proportion expression is the ability to represent proportional relationships using mathematical symbols and equations.";
    edu:partOf :ProportionInteraction.
:ProportionIdentification a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "Proportion identification is the ability to recognize situations where proportional relationships exist.";
    edu:partOf :ProportionInteraction.
:ProportionInteraction a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "Proportion interaction is the ability to analyze and manipulate proportional relationships to solve problems.";
    edu:partOf :ProportionSense.
:ProportionManipulation a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "Proportion manipulation is the ability to adjust or change the values in a proportion while maintaining the proportional relationship.";
    edu:partOf :ProportionInteraction.
:ProportionSense a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "Proportion sense is the ability to understand and reason about proportional relationships between quantities.";
    edu:partOf :IntuitiveMathematics.
:RatioEquivalence a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "Ratio equivalence is the understanding that different ratios can represent the same proportional relationship.";
    edu:expands :ProportionManipulation;
    edu:partOf :ProportionAbstraction.
:RatioInterpretation a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "Ratio interpretation is the ability to understand the meaning of a ratio and its relationship to the quantities involved.";
    edu:partOf :ProportionAbstraction.
:RationalNumbers a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "The understanding and application of numbers that can be expressed as the quotient or fraction of two integers, where the denominator is non-zero.";
    edu:expands :IntegerNumbers;
    edu:partOf :NumberSystems.
:RatioNotation a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "Applying the system of symbols and conventions used to represent ratios.";
    edu:partOf :ProportionAbstraction.
:Root a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "Finding the number that, when raised to a certain power, produces a given number.\n\nExample: The cube root of 64 is 4 because 4 ^ 3 = 64";
    edu:inverts :Exponentiation;
    edu:partOf :NumberOperations.
:SetTheory a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "The branch of mathematics that studies sets, which are collections of objects. It provides a fundamental language and tools for defining and working with mathematical objects.".
:ShapeCongruence a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "Understanding when two shapes are identical in size and shape, independently of their orientation.";
    edu:partOf :ShapeRecognition.
:ShapeRecognition a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "Identifying and naming different geometric shapes.";
    edu:partOf :SpatialSense.
:ShapeSymmetry a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "Understanding how a shape can be divided into identical halves that mirror each other.";
    edu:partOf :ShapeRecognition.
:SpatialModelling a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "Creating mental or physical representations of objects and their spatial relationships.";
    edu:partOf :SpatialSense.
:SpatialSense a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "Understanding shapes, sizes, positions, and movements in two and three dimensions.";
    edu:partOf :IntuitiveMathematics.
:Statistics a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "The branch of mathematics that provides a framework for collecting, organizing, analyzing, and interpreting data. It provides tools for quantifying and modeling randomness, variability, and uncertainty in data.".
:Subtraction a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "Finding the difference between two numbers.";
    edu:expands :Addition, :Difference;
    edu:partOf :NumberOperations.
:Sum a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "Combining quantities to determine their total amount for any type of mathematical object, including numbers.";
    edu:expands :Increment;
    edu:partOf :BaseOperations.
