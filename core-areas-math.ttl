@prefix : <http://edugraph.io/edu/>.
@prefix edu: <http://edugraph.io/edu#>.
@prefix owl: <http://www.w3.org/2002/07/owl#>.
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>.
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.
@prefix xml: <http://www.w3.org/XML/1998/namespace>.
@prefix xsd: <http://www.w3.org/2001/XMLSchema#>.

<http://edugraph.io/edu/> a owl:Ontology;
    owl:imports <http://edugraph.io/edu#>.
:AcuteAngle a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "An angle that measures less than 90 degrees.";
    edu:partOf :AngleConcept.
:AcuteTriangle a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "A triangle in which all three interior angles are acute angles.";
    edu:integrates :AcuteAngle;
    edu:partOf :Triangle.
:Addition a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "Adding numbers together.";
    edu:expands :Sum;
    edu:partOf :BaseOperations.
:AdjacentAngles a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "Two angles that share a common vertex and a common side but do not overlap.";
    edu:partOf :AngleRelations.
:Algebra a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "The branch of mathematics that generalizes arithmetics and where letters represent unknown numbers, allowing us to explore patterns, solve equations, and model real-world situations.".
:Analysis a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "The branch of mathematics that deals with continuous change and investigates concepts like limits, continuity, derivatives, integrals, and infinite series to study functions, their properties, and their behavior.".
:AngleCalculation a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "The calculation of the measurement of the space between two intersecting lines or surfaces.";
    edu:expands :AngleConcept;
    edu:partOf :GeometricCalculations.
:AngleConcept a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "The amount of rotation or divergence between two intersecting rays, lines or planes.";
    edu:expands :IntersectionRelation, :LineConcept;
    edu:partOf :GeometricConcepts.
:AngleRelations a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "The study of relationships between pairs of angles, such as those formed by intersecting lines.";
    edu:expands :AngleConcept;
    edu:partOf :GeometricRelations.
:AreaCalculation a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "The calculation of the extent or measurement of a surface.";
    edu:expands :LengthCalculation;
    edu:partOf :GeometricCalculations.
:Arithmetic a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "The branch of mathematics that deals with the properties and manipulation of numbers, including addition, subtraction, multiplication and division.".
:ArithmeticExpressions a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "The structured formulation and evaluation of numerical statements through the combination of values and operations, governed by mathematical laws and conventions such as the order of operations to represent and simplify quantitative relationships.";
    edu:expands :ArithmeticOperations;
    edu:partOf :Arithmetic.
:ArithmeticLaws a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "The fundamental rules that govern the manipulation and simplification of arithmetic expressions, ensuring consistent and predictable results.";
    edu:expands :ArithmeticOperations;
    edu:partOf :ArithmeticExpressions.
:ArithmeticOperations a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "The systematic application of mathematical rules and procedures to combine, transform, or calculate values through fundamental actions such as addition, subtraction, multiplication, and division.";
    edu:partOf :Arithmetic.
:ArithmeticSpaces a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "The classification, representation, and properties of different sets of numbers such as integers, fractions, decimals including the symbolic frameworks used to express numerical values and their relationships.";
    edu:partOf :Arithmetic.
:AssociativeLaw a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "The mathematical principle stating that the way in which numbers are grouped by parentheses does not change their sum or product.";
    edu:partOf :ArithmeticLaws.
:BaseOperations a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "The foundational application of mathematical rules and procedures to perform primary calculations through the core actions of addition, subtraction, multiplication, and division.";
    edu:partOf :ArithmeticOperations.
:Calculus a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "The branch of mathematics that provides tools for analyzing rates of change and accumulation. It deals with instantaneous rates of change that affect the slopes of curves, as well as with accumulation that affect areas under curves.".
:CartesianPlane a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "A two-dimensional plane defined by a horizontal axis and a vertical axis intersecting at a right angle.";
    edu:expands :PlaneConcept;
    edu:integrates :LineConcept, :PerpendicularityRelation;
    edu:partOf :GeometricVisualization.
:ChordCenterRelation a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "The relationship stating that a perpendicular line drawn from the center of a circle to a chord bisects the chord into two equal parts.";
    edu:integrates :PerpendicularityRelation;
    edu:partOf :CircleRelations.
:Circle a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "The study of circles, their properties, and related functions including Pi.";
    edu:expands :CircularShapeDrawing;
    edu:partOf :TwoDimensionalObjects.
:CircleRelations a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "The study of proportional and spatial relationships between various elements of a circle, such as its center, radius, diameter, circumference, arcs, chords, and tangent lines.";
    edu:expands :Circle;
    edu:partOf :GeometricRelations.
:CircularShapeDrawing a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "Circular shape drawing is the ability to create drawings or models of circular shapes.";
    edu:partOf :SpatialModelling.
:CollectionSense a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "Collection sense is the intuitive understanding of how objects are grouped and categorized as a foundational form of set theory.";
    edu:partOf :IntuitiveMathematics.
:CommutativeLaw a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "The mathematical principle stating that the order in which numbers are added or multiplied does not change their sum or product.";
    edu:partOf :ArithmeticLaws.
:ComplementaryAngles a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "Two angles whose sum is exactly 90 degrees.";
    edu:partOf :AngleRelations.
:ComputationalMathematics a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "The branch of mathematics that involves the development and application of mathematical methods and algorithms for solving problems using computers.".
:Cone a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "A three-dimensional geometric shape that tapers smoothly from a flat base to a point called the apex or vertex.";
    edu:integrates :Circle;
    edu:partOf :ThreeDimensionalObjects.
:CongruenceRelation a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "The relationship between geometric figures that have the exact same size and shape.";
    edu:expands :ShapeIdentity;
    edu:partOf :ShapeEquivalenceRelations;
    edu:translates :ShapeRotation.
:CoordinateAxes a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "The horizontal (x-axis) and vertical (y-axis) number lines that intersect at right angles to form the Cartesian plane.";
    edu:partOf :CartesianPlane.
:CoordinateDistance a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "The calculation of the straight-line distance between two points on the Cartesian plane using their coordinates.";
    edu:expands :PointPlotting;
    edu:integrates :DistanceCalculation;
    edu:partOf :GeometricVisualization.
:Cosine a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "The trigonometric function that is equal to the ratio of the side adjacent to an acute angle (in a right-angled triangle) to the hypotenuse.";
    edu:partOf :TrigonometricRelations.
:Cube a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "A solid geometric figure that has six congruent square faces where each pair of opposite faces is parallel.";
    edu:integrates :Square;
    edu:partOf :RectangularPrism.
:Cylinder a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "A three-dimensional solid consisting of two parallel circular bases connected by a curved surface.";
    edu:integrates :Circle, :Rectangle;
    edu:partOf :ThreeDimensionalObjects.
:DecimalArithmetic a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "The representation of rational numbers using a base-10 positional notation system, where a decimal point separates the integer component from a fractional component expressed as a sum of negative powers of ten.";
    edu:expands :FractionArithmetic, :NumerationWithDecimals;
    edu:partOf :RationalArithmetic.
:DecimalDivisorShift a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "Decimal equivalence is the understanding that decimals with trailing zeros represent the same decimal number.";
    edu:partOf :DecimalEquivalence.
:DecimalEquivalence a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "The rules and procedures for identifying or establishing the equality between different representations of the same rational value, specifically between fractions and their base-10 positional notation or between decimals with varying digits at subsequent negative powers of ten that maintain the same magnitude.";
    edu:expands :FractionEquivalence;
    edu:partOf :DecimalArithmetic.
:DecimalNotation a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "The system of symbols used to represent decimals, including the floating point and its meaning.";
    edu:expands :IntegerNotation;
    edu:partOf :DecimalArithmetic.
:DecimalPadding a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "The rules and procedures that adjust the digits following the floating point to ensure uniform decimal places as a part of decimal number operations such as addition.";
    edu:partOf :DecimalEquivalence.
:DecimalPointAlignment a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "The rules and procedures that align the floating point as a part of decimal number operations.";
    edu:partOf :DecimalArithmetic.
:DecimalRounding a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "The rules and procedures for approximating a decimal number to a specified degree of precision by adjusting the fractional component based on the value of digits at subsequent negative powers of ten.";
    edu:partOf :DecimalArithmetic.
:Decrement a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "Reducing a quantity by a specific amount.";
    edu:inverts :Increment;
    edu:partOf :FoundationalOperations.
:Difference a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "Determining the difference in quantities of mathematical object, including numbers where difference represents the amount by which one quantity is greater or less than another.";
    edu:expands :Decrement, :SetComparison;
    edu:inverts :Sum;
    edu:partOf :FoundationalOperations.
:DigitNotation a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "Digit notation uses symbols from 0 to 9 to represent any number.";
    edu:expands :NumericIdentity;
    edu:partOf :NumberNotation.
:Dilation a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "A transformation that produces an image that is the same shape as the original, but is a different size, altering the scale of the geometric object.";
    edu:expands :ShapeResizing;
    edu:partOf :GeometricTransformations.
:DistanceCalculation a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "The calculation of distance between two points.";
    edu:expands :MeasuringObjects;
    edu:partOf :GeometricCalculations.
:DistributiveLaw a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "The mathematical principle stating that multiplying a sum by a number gives the same result as multiplying each addend by the number and then adding the products together.";
    edu:partOf :ArithmeticLaws.
:Division a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "Dividing one number by another.";
    edu:inverts :Multiplication;
    edu:partOf :BaseOperations.
:EquilateralTriangle a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "A triangle in which all three sides are of equal length and all three angles are 60 degrees.";
    edu:partOf :Triangle.
:Exponentiation a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "Raising a number to a power, meaning multiplying it by itself a certain number of times.";
    edu:expands :Multiplication;
    edu:partOf :PowerOperations.
:ExpressionEvaluation a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "The process of calculating the value of an arithmetic expression by systematically applying operations according to established rules.";
    edu:integrates :ArithmeticLaws, :OrderOfOperations, :ParenthesesUsage;
    edu:partOf :ArithmeticExpressions.
:FoundationalOperations a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "Base operations are the fundamental arithmetic actions performed on numbers that all other arithmetic operations are based one.";
    edu:partOf :NumberSense.
:FractionArithmetic a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "The representation of rational numbers as a ratio of two integers, expressed in the form a/b, where the numerator (a) indicates a number of equal parts and the denominator (b) indicates how many of those parts make up a unit or whole.";
    edu:expands :NumerationWithFractions, :ProportionInteraction;
    edu:partOf :RationalArithmetic.
:FractionEquivalence a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "The principle that distinct representations of rational numbers in the form a/b can express the same ratio, where transformations between different numerators and denominators maintain the same value relative to the unit or whole.";
    edu:expands :RatioEquivalence;
    edu:partOf :FractionArithmetic.
:FractionNotation a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "The system of symbols used to represent fractions, including the numerator and denominator.";
    edu:expands :IntegerNotation;
    edu:partOf :FractionArithmetic.
:FractionSimplification a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "Reducing a fraction to its simplest form by dividing the numerator and denominator by their greatest common factor.\n\nExample: 12/18 simplifies to 2/3 by dividing both by 6";
    edu:partOf :FractionEquivalence.
:GeometricCalculations a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "The measurement and calculation of properties of geometric objects, such as perimeter, area, and volume.";
    edu:partOf :Geometry.
:GeometricConcepts a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "The fundamental concepts of geometry including points, lines, planes, and angles.";
    edu:partOf :Geometry.
:GeometricObjects a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "The study of specific geometric shapes and figures in one, two, and three dimensions.";
    edu:partOf :Geometry.
:GeometricRelations a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "The study of the relationships and interactions between geometric entities, such as congruence, similarity, parallelism, and symmetry.";
    edu:partOf :Geometry.
:GeometricTransformations a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "The application of transformations to geometric objects to alter their position, orientation, or scale, such as rotation, reflection, translation, and dilation.";
    edu:partOf :Geometry.
:GeometricVisualization a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "The study of geometry using a coordinate system to define the position of points, lines, and shapes.";
    edu:partOf :Geometry.
:Geometry a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "The branch of mathematics that studies shapes, the sizes, positions, and dimensions of things. It explores properties of points, lines, planes, and solids.".
:GroupRecognition a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "The ability to perceive a collection of distinct physical objects or visual elements as a single, unified group or set.";
    edu:partOf :CollectionSense.
:Hexagon a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "A polygon with six edges and six vertices.";
    edu:partOf :Polygon.
:Increment a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "Raising a quantity by a certain amount.";
    edu:expands :NumericOrder;
    edu:partOf :FoundationalOperations.
:IntegerArithmetic a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "The understanding and application of whole numbers, their additive inverses (negative numbers), and zero, representing discrete values that do not contain fractional or decimal components.";
    edu:expands :NumerationWithIntegers;
    edu:partOf :ArithmeticSpaces.
:IntegerNotation a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "Applying the system of symbols used to represent integers.\n\nExample: Using the symbols -3, 0, and 12 to represent integers.";
    edu:expands :DigitNotation;
    edu:partOf :IntegerArithmetic.
:IntegerRegrouping a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "Also referred to as carrying or borrowing. The process of exchanging values between place value positions to facilitate arithmetic operations such as addition and subtraction within the set of integer numbers.";
    edu:partOf :IntegerArithmetic.
:IntegerSigns a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "The identification and application of positive (+) and negative (-) symbols to indicate an integer's direction and magnitude relative to zero.";
    edu:partOf :IntegerArithmetic.
:IntersectionOfCollections a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "The identification of objects that belong to two overlapping physical groups, often visualized through intersecting boundaries like Venn diagrams made of physical hoops.";
    edu:expands :ObjectSorting;
    edu:partOf :CollectionSense.
:IntersectionRelation a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "The relationship between geometric entities that share one or more common points where they meet or cross.";
    edu:expands :LineConcept;
    edu:partOf :PositionalRelations.
:IntervalsWithInfinity a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "Intervals with infinity is used to represent sets of numbers with unbounded limits.";
    edu:partOf :NumerationWithIntervals.
:IntuitiveMathematics a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "The branch of mathematics that focuses on understanding foundational math concepts through direct experience and visualization, gradually familiarizing students with increasingly formal and abstract representations of math concepts.".
:IsoscelesTriangle a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "A triangle that has at least two sides of equal length.";
    edu:partOf :Triangle.
:Kite a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "A quadrilateral with two distinct pairs of equal-length sides that are adjacent to each other.";
    edu:partOf :Quadrilateral.
:LengthCalculation a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "The calculation of the linear extent or measurement of a geometric object.";
    edu:expands :DistanceCalculation;
    edu:partOf :GeometricCalculations.
:LinearShapeDrawing a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "Linear shape drawing is the ability to create drawings or models of shapes with straight sides.";
    edu:partOf :SpatialModelling.
:LineConcept a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "A straight, one-dimensional figure that has no thickness and extends infinitely in both directions.";
    edu:expands :PointConcept;
    edu:partOf :GeometricConcepts.
:LineGraphing a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "The process of representing a straight line on the coordinate plane, typically by plotting points or using a linear equation.";
    edu:expands :PointPlotting;
    edu:integrates :LineConcept;
    edu:partOf :GeometricVisualization.
:LineSegment a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "A part of a line that is bounded by two distinct end points, and contains every point on the line that is between its endpoints.";
    edu:partOf :OneDimensionalObjects.
:Logarithm a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "Finding the exponent to which a base must be raised to produce a given number.";
    edu:inverts :Exponentiation;
    edu:partOf :PowerOperations.
:Logic a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "The branch of mathematics that studies reasoning and valid arguments. It provides a framework for determining whether something is true or false based on given premises. It is the foundation for constructing proofs, ensuring that conclusions follow logically from their premises.".
:LowestCommonDenominator a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "Finding the smallest common multiple of the denominators of two or more fractions.\n\nExample: The lowest common denominator of 1/4 and 1/6 is 12.";
    edu:partOf :FractionEquivalence.
:Measurement a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "Measurement is the process of assigning numbers to describe the properties of objects, such as length, weight, or volume.";
    edu:partOf :SpatialSense.
:MeasuringObjects a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "Measuring objects involves determining their physical dimensions using appropriate tools and units.";
    edu:partOf :Measurement.
:MeasuringTime a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "Measuring time involves quantifying the duration of events or the intervals between them.";
    edu:partOf :Measurement.
:MidpointCalculation a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "The process of finding the exact center point of a line segment on the coordinate plane by averaging the coordinates of its endpoints.";
    edu:integrates :LineSegment;
    edu:partOf :GeometricVisualization.
:Modulo a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "Finding the remainder after dividing one number by another.";
    edu:partOf :BaseOperations.
:Multiplication a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "Multiplying two or multiple numbers.";
    edu:expands :Addition;
    edu:partOf :BaseOperations.
:NumberNotation a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "Number notation is the system of symbols and rules used to express numerical values.";
    edu:partOf :NumberSense.
:NumberSense a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "Number sense is the intuitive understanding of numbers, their magnitudes, and how they relate to each other.";
    edu:partOf :IntuitiveMathematics.
:NumberTheory a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "The branch of mathematics that studies the properties of numbers, particularly integers (whole numbers). It explores things like prime numbers, divisibility, and number patterns.".
:Numeration a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "Numeration encompasses counting, ordering, and grouping numbers.";
    edu:partOf :NumberSense.
:NumerationWithDecimals a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "Numeration with decimals encompasses understanding the place value and magnitude of decimal numbers on the number line.";
    edu:expands :NumerationWithFractions;
    edu:partOf :Numeration.
:NumerationWithFractions a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "Numeration with fractions encompasses understanding the density of fraction numbers on the number line.";
    edu:expands :NumerationWithIntegers;
    edu:partOf :Numeration.
:NumerationWithIntegers a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "Numeration with integers includes understanding the sequence and magnitude of whole numbers.";
    edu:partOf :Numeration.
:NumerationWithIntervals a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "Numeration with intervals is used to represent sets of numbers with specific limits.";
    edu:partOf :Numeration.
:NumericComparison a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "Numeric comparison involves evaluating whether one number is greater than, less than, or equal to another.";
    edu:partOf :NumberSense.
:NumericIdentity a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "Numeric identity refers to the understanding that a number remains the same regardless of its representation.";
    edu:partOf :NumericComparison.
:NumericOrder a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "Numeric order refers to the arrangement of numbers in ascending or descending sequence based on their magnitude.";
    edu:expands :NumericIdentity;
    edu:partOf :NumericComparison.
:ObjectSorting a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "The process of categorizing and grouping physical objects into distinct collections based on shared observable attributes like color, shape, or size.";
    edu:expands :GroupRecognition;
    edu:partOf :CollectionSense.
:ObtuseAngle a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "An angle that measures more than 90 degrees but less than 180 degrees.";
    edu:partOf :AngleConcept.
:ObtuseTriangle a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "A triangle that has one obtuse angle.";
    edu:integrates :ObtuseAngle;
    edu:partOf :Triangle.
:OneDimensionalObjects a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "Geometric objects that have only length, such as line segments and rays.";
    edu:expands :LinearShapeDrawing;
    edu:partOf :GeometricObjects.
:OrderOfOperations a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "The standard set of rules that dictates the sequence in which multiple operations in an arithmetic expression must be performed to ensure a single, correct result.";
    edu:expands :ArithmeticOperations;
    edu:partOf :ArithmeticExpressions.
:Origin a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "The point (0,0) where the coordinate axes intersect on the Cartesian plane.";
    edu:integrates :IntersectionRelation;
    edu:partOf :CartesianPlane.
:ParallelismRelation a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "The relationship between lines or planes that are always the same distance apart and never intersect.";
    edu:inverts :IntersectionRelation;
    edu:partOf :PositionalRelations.
:Parallelogram a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "The study of four-sided polygons with two pairs of parallel sides, their properties, and related measurements.";
    edu:integrates :ParallelismRelation;
    edu:partOf :Quadrilateral.
:ParenthesesUsage a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "The use of grouping symbols in arithmetic expressions to override the standard order of operations and specify which calculations should be performed first.";
    edu:expands :OrderOfOperations;
    edu:partOf :ArithmeticExpressions.
:Pentagon a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "A polygon with five edges and five vertices.";
    edu:partOf :Polygon.
:PerimeterCalculation a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "The calculation of the continuous line forming the boundary of a closed geometric figure.";
    edu:expands :LengthCalculation;
    edu:partOf :GeometricCalculations.
:PerpendicularityRelation a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "The relationship between two geometric objects that intersect at a right angle (90 degrees).";
    edu:expands :IntersectionRelation;
    edu:partOf :PositionalRelations.
:Pi a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "The mathematical constant representing the ratio of a circle's circumference to its diameter.";
    edu:integrates :RatioInterpretation;
    edu:partOf :CircleRelations.
:PlaneConcept a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "A flat, two-dimensional surface that extends infinitely far.";
    edu:expands :LineConcept;
    edu:partOf :GeometricConcepts.
:PointConcept a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "A precise location or position on a plane, usually represented by a dot.";
    edu:expands :SpatialModelling;
    edu:partOf :GeometricConcepts.
:PointPlotting a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "The process of locating and marking a point on a coordinate plane using a pair of numerical coordinates.";
    edu:expands :NumericOrder, :PointConcept;
    edu:partOf :GeometricVisualization.
:Polygon a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "The study of closed, multi-sided geometric figures formed by straight line segments, their properties, and related measurements.";
    edu:integrates :LineSegment;
    edu:partOf :TwoDimensionalObjects.
:PositionalRelations a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "The study of relationships describing how geometric lines, planes, or segments interact, intersect, or positionally relate to one another in space.";
    edu:partOf :GeometricRelations.
:PowerOperations a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "The specialized application of mathematical rules and procedures to perform higher-order calculations through the actions of exponentiation, root extraction, and logarithmic derivation.";
    edu:partOf :ArithmeticOperations.
:Prism a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "A solid geometric figure that has two congruent and parallel bases and lateral faces that are parallelograms.";
    edu:integrates :CongruenceRelation, :ParallelismRelation;
    edu:partOf :ThreeDimensionalObjects.
:ProportionAbstraction a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "Proportion abstraction is the ability to generalize proportional relationships and apply them to new situations.";
    edu:partOf :ProportionSense.
:ProportionExpression a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "Proportion expression is the ability to represent proportional relationships using mathematical symbols and equations.";
    edu:partOf :ProportionInteraction.
:ProportionIdentification a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "Proportion identification is the ability to recognize situations where proportional relationships exist.";
    edu:partOf :ProportionInteraction.
:ProportionInteraction a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "Proportion interaction is the ability to analyze and manipulate proportional relationships to solve problems.";
    edu:partOf :ProportionSense.
:ProportionManipulation a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "Proportion manipulation is the ability to adjust or change the values in a proportion while maintaining the proportional relationship.";
    edu:partOf :ProportionInteraction.
:ProportionSense a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "Proportion sense is the ability to understand and reason about proportional relationships between quantities.";
    edu:partOf :IntuitiveMathematics.
:Pyramid a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "A polyhedron formed by connecting a polygonal base and a point, called the apex.";
    edu:integrates :Polygon;
    edu:partOf :ThreeDimensionalObjects.
:Quadrants a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "The four regions into which the coordinate axes divide the Cartesian plane, typically numbered I, II, III, and IV.";
    edu:partOf :CartesianPlane.
:Quadrilateral a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "A polygon with four edges and four vertices.";
    edu:partOf :Polygon.
:RadiusDiameterRelation a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "The proportional relationship stating that the diameter of a circle is exactly twice the length of its radius.";
    edu:partOf :CircleRelations.
:RatioEquivalence a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "Ratio equivalence is the understanding that different ratios can represent the same proportional relationship.";
    edu:expands :ProportionManipulation;
    edu:partOf :ProportionAbstraction.
:RatioInterpretation a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "Ratio interpretation is the ability to understand the meaning of a ratio and its relationship to the quantities involved.";
    edu:partOf :ProportionAbstraction.
:RationalArithmetic a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "The understanding and application of numbers that can be expressed as the quotient or fraction of two integers, where the denominator is non-zero.";
    edu:expands :IntegerArithmetic;
    edu:partOf :ArithmeticSpaces.
:RatioNotation a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "Applying the system of symbols and conventions used to represent ratios.";
    edu:partOf :ProportionAbstraction.
:RayConcept a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "The study of rays and their properties, including endpoints, directionality, and infinite extension in one direction.";
    edu:expands :LineConcept;
    edu:partOf :GeometricConcepts.
:Rectangle a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "The study of four-sided polygons with four right angles, their properties, and related measurements.";
    edu:integrates :RightAngle;
    edu:partOf :Parallelogram.
:RectangularPrism a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "A solid geometric figure that has six rectangular faces where each pair of opposite faces is congruent and parallel.";
    edu:integrates :Rectangle;
    edu:partOf :Prism.
:Reflection a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "A transformation that flips a geometric figure across a line, creating a mirror image.";
    edu:expands :ShapeReflection;
    edu:partOf :GeometricTransformations.
:ReflexAngle a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "An angle that measures more than 180 degrees but less than 360 degrees.";
    edu:partOf :AngleConcept.
:Rhombus a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "A parallelogram with four equal-length sides.";
    edu:partOf :Parallelogram.
:RightAngle a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "An angle of exactly 90 degrees, corresponding to a quarter turn.";
    edu:partOf :AngleConcept.
:RightTriangle a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "A triangle that has one right angle.";
    edu:integrates :RightAngle;
    edu:partOf :Triangle.
:Root a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "Finding the number that, when raised to a certain power, produces a given number.\n\nExample: The cube root of 64 is 4 because 4 ^ 3 = 64";
    edu:inverts :Exponentiation;
    edu:partOf :PowerOperations.
:Rotation a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "A transformation that turns a geometric figure around a fixed point, known as the center of rotation, by a specific angle.";
    edu:expands :ShapeRotation;
    edu:partOf :GeometricTransformations.
:ScaleneTriangle a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "A triangle in which all three sides have different lengths.";
    edu:partOf :Triangle.
:SetComparison a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "The intuitive visual comparison of two bounded collections to determine relative quantities such as more, less, or equal, relying on spatial arrangement rather than formal counting.";
    edu:expands :GroupRecognition;
    edu:partOf :CollectionSense.
:SetTheory a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "The branch of mathematics that studies sets, which are collections of objects. It provides a fundamental language and tools for defining and working with mathematical objects.".
:ShapeEquivalenceRelations a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "The study of relationships that compare the intrinsic shape, size, and mapping of geometric figures to one another.";
    edu:partOf :GeometricRelations.
:ShapeIdentity a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "Understanding when two shapes are identical in size and shape, independently of their orientation.";
    edu:partOf :ShapeRecognition.
:ShapePlotting a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "The process of drawing geometric shapes, such as polygons, on a coordinate plane by plotting their vertices.";
    edu:expands :PointPlotting;
    edu:integrates :Polygon;
    edu:partOf :GeometricVisualization.
:ShapeRecognition a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "Identifying and naming different geometric shapes.";
    edu:partOf :SpatialSense.
:ShapeReflection a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "Understanding how a shape can be divided into identical halves that mirror each other.";
    edu:partOf :ShapeRecognition.
:ShapeResizing a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "Understanding how a shape can be increased or decreased in size while maintaining its original form.";
    edu:partOf :ShapeRecognition.
:ShapeRotation a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "Understanding how a shape can be turned around a fixed point while maintaining its original size and form.";
    edu:partOf :ShapeRecognition.
:ShapeTranslation a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "Understanding how a shape can be slid in a specific direction without altering its size or orientation.";
    edu:partOf :ShapeRecognition.
:ShearTransformation a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "A transformation that displaces each point of a geometric figure in a given direction by an amount proportional to its signed distance from a line parallel to that direction.";
    edu:partOf :GeometricTransformations.
:SimilarityRelation a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "The relationship between geometric figures that have the same shape, with corresponding angles being equal and corresponding sides being in proportion.";
    edu:expands :ShapeResizing;
    edu:partOf :ShapeEquivalenceRelations;
    edu:translates :ShapeRotation.
:Sine a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "The trigonometric function that is equal to the ratio of the side opposite a given angle (in a right-angled triangle) to the hypotenuse.";
    edu:partOf :TrigonometricRelations.
:SlopeConcept a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "The measure of the steepness and direction of a line, calculated as the ratio of the vertical change (rise) to the horizontal change (run) between two points.";
    edu:integrates :RatioInterpretation;
    edu:partOf :GeometricVisualization.
:SpatialModelling a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "Creating mental or physical representations of objects and their spatial relationships.";
    edu:partOf :SpatialSense.
:SpatialSense a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "Understanding shapes, sizes, positions, and movements in two and three dimensions.";
    edu:partOf :IntuitiveMathematics.
:Sphere a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "A solid geometric figure that is perfectly round and defined by a surface where every point is equidistant from a central point.";
    edu:expands :Circle;
    edu:partOf :ThreeDimensionalObjects.
:Square a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "The study of four-sided polygons with four right angles and four equal sides, their properties, and related measurements.";
    edu:integrates :RightAngle;
    edu:partOf :Rectangle.
:Statistics a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "The branch of mathematics that provides a framework for collecting, organizing, analyzing, and interpreting data. It provides tools for quantifying and modeling randomness, variability, and uncertainty in data.".
:StraightAngle a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "An angle that measures exactly 180 degrees, forming a straight line.";
    edu:partOf :AngleConcept.
:SubsetIdentification a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "The ability to recognize and isolate a smaller specific group of objects within a larger bounded collection based on a distinguishing visual attribute.";
    edu:expands :ObjectSorting;
    edu:partOf :CollectionSense.
:Subtraction a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "Finding the difference between two numbers.";
    edu:expands :Difference;
    edu:inverts :Addition;
    edu:partOf :BaseOperations.
:Sum a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "Combining quantities to determine their total amount for any type of mathematical object, including numbers.";
    edu:expands :Increment, :UnionOfCollections;
    edu:partOf :FoundationalOperations.
:SupplementaryAngles a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "Two angles whose sum is exactly 180 degrees.";
    edu:partOf :AngleRelations.
:SurfaceAreaCalculation a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "The calculation of the total area of the surface of a three-dimensional object.";
    edu:expands :AreaCalculation;
    edu:partOf :GeometricCalculations.
:SymmetryRelation a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "The property of a geometric figure to be invariant under certain transformations, such as reflection, rotation, or translation.";
    edu:expands :ShapeReflection;
    edu:partOf :ShapeEquivalenceRelations;
    edu:translates :ShapeResizing, :ShapeRotation.
:Tangent a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "The trigonometric function that is equal to the ratio of the side opposite a given angle to the side adjacent to that angle.";
    edu:partOf :TrigonometricRelations.
:TangentRadiusRelation a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "The geometric rule stating that a tangent line to a circle is perpendicular to the radius at the exact point of tangency.";
    edu:integrates :PerpendicularityRelation;
    edu:partOf :CircleRelations.
:ThreeDimensionalObjects a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "Solid geometric figures that have length, width, and depth, such as spheres, cubes, and cylinders.";
    edu:expands :TwoDimensionalObjects;
    edu:partOf :GeometricObjects.
:Translation a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "A transformation that slides a geometric figure in a specific direction and by a specific distance without altering its shape, size, or orientation.";
    edu:expands :ShapeTranslation;
    edu:partOf :GeometricTransformations.
:Trapezoid a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "A quadrilateral with at least one pair of parallel sides.";
    edu:partOf :Quadrilateral.
:Triangle a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "The study of three-sided polygons, their properties, and related measurements.";
    edu:partOf :Polygon.
:TrigonometricRelations a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "The study of the relationships between the angles and side lengths of triangles, primarily focusing on right-angled triangles.";
    edu:partOf :GeometricRelations.
:TwoDimensionalObjects a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "Flat geometric figures that have length and width, such as polygons and circles.";
    edu:expands :OneDimensionalObjects;
    edu:partOf :GeometricObjects.
:UnionOfCollections a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "The physical or visual act of combining two or more distinct, bounded collections into a single larger group, removing the boundaries between them.";
    edu:expands :GroupRecognition;
    edu:partOf :CollectionSense.
:VectorConcept a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "A quantity characterized by both magnitude and direction, typically represented as a directed line segment.";
    edu:expands :LineConcept;
    edu:partOf :GeometricConcepts.
:VerticalAngles a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "The pairs of opposite angles made by two intersecting lines.";
    edu:partOf :AngleRelations.
:VolumeCalculation a owl:NamedIndividual, edu:Area;
    rdfs:isDefinedBy "The calculation of the amount of space that a substance or object occupies.";
    edu:expands :AreaCalculation;
    edu:partOf :GeometricCalculations.
