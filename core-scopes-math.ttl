@prefix : <http://edugraph.io/edu/>.
@prefix edu: <http://edugraph.io/edu#>.
@prefix owl: <http://www.w3.org/2002/07/owl#>.
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>.
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.
@prefix xml: <http://www.w3.org/XML/1998/namespace>.
@prefix xsd: <http://www.w3.org/2001/XMLSchema#>.

<http://edugraph.io/edu/> a owl:Ontology;
    owl:imports <http://edugraph.io/edu#>.
:Abacus a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Represents numbers with an abacus.";
    edu:partOf :PhysicalNumbers.
:Above a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves relative vertical orientation situated at a higher level or position than a reference point.";
    edu:partOf :SpatialDirection.
:AbstractionScope a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves abstract concepts such as shapes or numbers.".
:AdditiveCount a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Counts manifested objects additively.";
    edu:partOf :QuantityMeasurement.
:After a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves identifying a later chronological point or a subsequent position within a sequence.";
    edu:partOf :TemporalDirection.
:Ahead a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves relative horizontal orientation situated at a further forward position or direction than a reference point.";
    edu:partOf :SpatialDirection.
:AnalogClock a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves an analog clock.";
    edu:integrates :HourIntervals, :MinuteIntervals, :SecondIntervals;
    edu:partOf :TimeMeasurement.
:AngleMeasurement a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves angle measurement.";
    edu:partOf :MeasurementScope.
:ArabicNumerals a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Represents numbers with arabic numerals.";
    edu:partOf :Numerals;
    edu:translates :Base10.
:BalanceScale a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves a balance scale.";
    edu:integrates :GramScale, :KilogramScale;
    edu:partOf :WeightMeasurement.
:Banknotes a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Represents currency with banknotes.";
    edu:partOf :CurrencyRepresentation;
    edu:translates :MajorDenomination.
:Base10 a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Represents numbers in base 10 (decimal).";
    edu:partOf :NumericBase.
:Base16 a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Represents numbers in base 16 (hexadecimal).";
    edu:partOf :NumericBase.
:Base2 a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Represents numbers in base 2 (binary).";
    edu:partOf :NumericBase.
:Base8 a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Represents numbers in base 8 (octal).";
    edu:partOf :NumericBase.
:BaseTenBlocks a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Represents numbers with a base ten blocks.";
    edu:partOf :PhysicalNumbers;
    edu:translates :Base10.
:Before a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves identifying an earlier chronological point or a preceding position within a sequence.";
    edu:partOf :TemporalDirection.
:Behind a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves relative horizontal orientation situated at a further backward position or direction than a reference point.";
    edu:partOf :SpatialDirection.
:Below a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves relative vertical orientation situated at a lower level or position than a reference point.";
    edu:partOf :SpatialDirection.
:Beside a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves relative horizontal orientation situated at a side position or direction than a reference point.";
    edu:partOf :SpatialDirection.
:BoxArrangement a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves the rectangular positioning and two-dimensional organization of objects.";
    edu:partOf :ObjectArrangement.
:Calendar a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves a calendar.";
    edu:integrates :DayIntervals, :MonthIntervals, :WeekIntervals, :YearIntervals;
    edu:partOf :TimeMeasurement.
:CardinalDirections a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves the primary orientation indicators of North, South, East, and West.";
    edu:partOf :CompassDirections.
:CartesianCoordinateSystem a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Represents functions and shapes in the cartesian coordinate system.";
    edu:partOf :VisualGeometry;
    edu:translates :ThreeDimensional, :TwoDimensional.
:CelsiusScale a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves temperature ranges or differences on the Celsius scale.";
    edu:partOf :TemperatureAbstraction.
:CentimeterScale a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves distances expressed in centimeters.";
    edu:partOf :MetricScale.
:CircularArrangement a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves the radial positioning and curvilinear organization of objects.";
    edu:partOf :ObjectArrangement.
:Coins a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Represents currency with coins.";
    edu:partOf :CurrencyRepresentation;
    edu:translates :MajorDenomination, :MinorDenomination.
:CompassDirections a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves cardinal and intercardinal orientation indicators.";
    edu:partOf :DirectionalRepresentation.
:CountingSymbols a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves counting symbols.";
    edu:partOf :VisualNumbers.
:CubicMeterScale a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves cubic meters to measure volumes.";
    edu:partOf :VolumeAbstraction.
:CurrencyAbstraction a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves currency or monetary concepts.";
    edu:partOf :AbstractionScope.
:CurrencyDenomination a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves the denominations of a currency.";
    edu:partOf :CurrencyAbstraction.
:CurrencyRepresentation a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Represents currency.";
    edu:partOf :RepresentationalScope.
:CurrencySystem a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves a specific currency system.";
    edu:partOf :CurrencyAbstraction.
:DayIntervals a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Time expressed in intervals of days.";
    edu:partOf :TimeIntervals.
:DecimalNumbers a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves numbers represented using a base-ten positional notation system within the real numeric space.";
    edu:partOf :RationalNumbers.
:DegreeScale a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves degrees (°) to express the rotation of objects, oftentimes used to express the angle of two rays. Degrees are fractions of a circle rotation, where 360° represents a full circle, 180° a half circle and 90° a quarter circle.";
    edu:partOf :RotationAbstraction.
:DerivedCount a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Counts manifested objects based on logical derivation of know facts.";
    edu:partOf :QuantityMeasurement.
:DigitalClock a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves a digital clock.";
    edu:integrates :HourIntervals, :MinuteIntervals, :SecondIntervals;
    edu:partOf :TimeMeasurement.
:DigitalScale a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves a digital scale.";
    edu:integrates :GramScale, :KilogramScale, :MilligramScale;
    edu:partOf :WeightMeasurement.
:DimensionalAbstraction a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves spatial dimensions with or without time or hyperdimensional concepts.";
    edu:partOf :AbstractionScope.
:DirectionalRepresentation a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves direction or orientation concepts.";
    edu:partOf :RepresentationalScope.
:DistanceAbstraction a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves distance or length concepts.";
    edu:partOf :AbstractionScope.
:Dollar a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves the Dollar currency.";
    edu:integrates :MajorDenomination, :MinorDenomination;
    edu:partOf :CurrencySystem.
:East a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves the cardinal direction East.";
    edu:partOf :CardinalDirections.
:Equal a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves the comparison of entities indicating they have the exact same quantity, size, or value.";
    edu:partOf :OrderAbstraction.
:Euro a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves the Euro currency.";
    edu:integrates :MajorDenomination, :MinorDenomination;
    edu:partOf :CurrencySystem.
:Foldable a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves the physical property of objects that allows for bending or overlapping of sections through flexible joints or creases to reduce volume or change configuration.";
    edu:partOf :ShapeProperties.
:FourDimensional a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves three spatial dimensions and time.";
    edu:expands :ThreeDimensional;
    edu:partOf :DimensionalAbstraction.
:FractionNumbers a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves numbers represented as a numerator and a denominator within the real numeric space.";
    edu:partOf :RationalNumbers.
:Gas a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves the identification and description of matter with no definite shape and no definite volume (example: vapor).";
    edu:partOf :StateProperties.
:Geoboard a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Represents geometric shapes with a geoboard.";
    edu:partOf :PhysicalGeometry.
:GeometryRepresentation a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves a geometric representation.";
    edu:partOf :RepresentationalScope.
:GramScale a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Weights measured in grams.";
    edu:partOf :WeightAbstraction.
:Greater a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves the comparison of two entities where one has a larger quantity, size, or value than the other.";
    edu:partOf :OrderAbstraction.
:HourIntervals a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Time expressed in intervals of hours in a day.";
    edu:partOf :TimeIntervals.
:HyperDimensional a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves more dimensions than three spatial dimensions and time.";
    edu:expands :FourDimensional;
    edu:partOf :DimensionalAbstraction.
:ImageObjects a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves graphic elements defined by a grid of pixels such as photographs and digital paintings.";
    edu:partOf :ObjectTypes.
:ImaginaryNumbers a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves numbers within the imaginary numeric space.";
    edu:expands :IrrationalNumbers;
    edu:partOf :NumericSpace.
:IntegerNumbers a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves whole numbers and their negative counterparts within the real numeric space.";
    edu:partOf :RealNumbers.
:IntercardinalDirections a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves the secondary orientation indicators of Northeast, Southeast, Southwest, and Northwest.";
    edu:partOf :CompassDirections.
:IrrationalNumbers a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves numbers that cannot be expressed as a ratio of integers within the real numeric space.";
    edu:expands :RationalNumbers;
    edu:partOf :RealNumbers.
:KelvinScale a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves temperature ranges or differences on the Kelvin scale.";
    edu:partOf :TemperatureAbstraction.
:KilogramScale a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Weights measured in kilograms.";
    edu:partOf :WeightAbstraction.
:KilometerScale a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "involves distances expressed in kilometers.";
    edu:partOf :MetricScale.
:LaserRuler a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves a laser ruler.";
    edu:integrates :MicrometerScale;
    edu:partOf :LengthMeasurement.
:Least a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves the comparison of three or more entities to identify the one with the smallest quantity, size, or value.";
    edu:expands :Less;
    edu:inverts :Most;
    edu:partOf :OrderAbstraction.
:Left a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves relative horizontal orientation situated at the left side position or direction than a reference point.";
    edu:partOf :SpatialDirection.
:LengthMeasurement a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves length measurement.";
    edu:partOf :MeasurementScope.
:Less a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves the comparison of two entities where one has a smaller quantity, size, or value than the other.";
    edu:inverts :Greater;
    edu:partOf :OrderAbstraction.
:LinearArrangement a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves the sequential positioning and one-dimensional organization of objects.";
    edu:partOf :ObjectArrangement.
:LinkingCubes a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Represents numbers with linking cubes.";
    edu:partOf :PhysicalNumbers;
    edu:translates :Base10.
:Liquid a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves the identification and description of matter with a definite volume and no definite shape (example: water).";
    edu:partOf :StateProperties.
:LiquidVolumes a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves liquid volumes as means of measurement.";
    edu:integrates :LiterScale, :MilliliterScale;
    edu:partOf :VolumeMeasurement.
:LiterScale a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves liters to measure volumes.";
    edu:partOf :VolumeAbstraction.
:MajorDenomination a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves the major denomination of a currency. For example \"Dollar\" in US Dollar and \"Euro\" in Euro.";
    edu:partOf :CurrencyDenomination;
    edu:translates :IntegerNumbers.
:MeasurementScope a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves the measurement of manifested objects shapes.".
:MechanicalAbstraction a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves physical properties or mechanical concepts.";
    edu:partOf :AbstractionScope.
:MeterScale a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves distance expressed in meters.";
    edu:expands :Numberline;
    edu:partOf :MetricScale.
:MetricScale a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves distances expressed in meters.";
    edu:partOf :DistanceAbstraction.
:MicrometerScale a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "involves distances expressed in micrometers.";
    edu:partOf :MetricScale.
:MilligramScale a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Weights measured in milligrams.";
    edu:partOf :WeightAbstraction.
:MilliliterScale a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves milliliters to measure volumes.";
    edu:partOf :VolumeAbstraction.
:MillimeterScale a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves distances expressed in millimeters";
    edu:partOf :MetricScale.
:MillisecondIntervals a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Time expressed in intervals of milliseconds.";
    edu:partOf :TimeIntervals.
:MinorDenomination a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves the minor denomination of a currency. For example \"Cent\" in US Dollar and Euro.";
    edu:partOf :CurrencyDenomination;
    edu:translates :DecimalNumbers, :FractionNumbers.
:MinuteIntervals a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Time expressed an intervals of minutes.";
    edu:partOf :TimeIntervals.
:MonthIntervals a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Time expressed in intervals of months.";
    edu:partOf :TimeIntervals.
:Most a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves the comparison of three or more entities to identify the one with the largest quantity, size, or value.";
    edu:expands :Greater;
    edu:partOf :OrderAbstraction.
:NanometerScale a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves distances expressed in nanometers.";
    edu:partOf :MetricScale.
:NanosecondIntervals a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Time expressed in intervals of nanoseconds.";
    edu:partOf :TimeIntervals.
:North a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves the cardinal direction North.";
    edu:partOf :CardinalDirections.
:Northeast a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves the intercardinal direction Northeast.";
    edu:partOf :IntercardinalDirections.
:Northwest a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves the intercardinal direction Northwest.";
    edu:partOf :IntercardinalDirections.
:Numberline a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Represents numbers with a number line.";
    edu:partOf :SpatialNumbers;
    edu:translates :OneDimensional.
:NumberRepresentation a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Represents numbers.";
    edu:partOf :RepresentationalScope.
:NumbersLarger10 a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Only involves numbers larger than 10.";
    edu:expands :NumbersSmaller10;
    edu:partOf :NumericRange;
    edu:translates :BaseTenBlocks, :LinkingCubes, :NumberTiles.
:NumbersLarger100 a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Only involves numbers larger than 100.";
    edu:expands :NumbersLarger20, :NumbersSmaller100;
    edu:partOf :NumericRange.
:NumbersLarger1000 a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Only involves numbers larger than 1000.";
    edu:expands :NumbersLarger100, :NumbersSmaller1000;
    edu:partOf :NumericRange.
:NumbersLarger20 a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Only Involves numbers larger than 20.";
    edu:expands :NumbersLarger10, :NumbersSmaller20;
    edu:partOf :NumericRange.
:NumbersSmaller10 a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Only involves numbers smaller than 10";
    edu:partOf :NumericRange;
    edu:translates :CountingSymbols, :TenFrame.
:NumbersSmaller100 a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Only involves numbers smaller than 100";
    edu:expands :NumbersSmaller20;
    edu:partOf :NumericRange.
:NumbersSmaller1000 a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Only involves numbers smaller than 1000";
    edu:expands :NumbersSmaller100;
    edu:partOf :NumericRange.
:NumbersSmaller20 a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Only involves numbers smaller than 20";
    edu:expands :NumbersSmaller10;
    edu:partOf :NumericRange.
:NumbersWithNegatives a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves negative numbers.";
    edu:expands :NumbersWithZero, :NumbersWithoutNegatives;
    edu:partOf :NumericSign.
:NumbersWithoutNegatives a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Does not involve negative numbers.";
    edu:partOf :NumericSign.
:NumbersWithoutZero a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Does not involve zero as a number.";
    edu:partOf :NumericZero.
:NumbersWithZero a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves zero as a number.";
    edu:expands :NumbersWithoutZero;
    edu:partOf :NumericZero.
:NumberTiles a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves number tiles.";
    edu:partOf :VisualNumbers;
    edu:translates :Base10.
:Numerals a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Represents numbers with numerals.";
    edu:partOf :NumberRepresentation.
:NumericAbstraction a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves numbers or number concepts.";
    edu:partOf :AbstractionScope.
:NumericBase a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves numbers with a certain numeric base.";
    edu:partOf :NumericAbstraction.
:NumericRange a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves numbers within a certain range.";
    edu:partOf :NumericAbstraction.
:NumericSign a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves the sign (positive, negative, or neutral) of numbers.";
    edu:partOf :NumericAbstraction.
:NumericSpace a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves numbers within a certain numeric space.";
    edu:partOf :NumericAbstraction.
:NumericZero a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves the inclusion or exclusion of zero.";
    edu:partOf :NumericAbstraction.
:ObjectArrangement a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves the relative positioning and spatial organization of objects.";
    edu:partOf :ObjectRepresentation.
:ObjectRepresentation a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves the representation of objects.";
    edu:partOf :RepresentationalScope.
:ObjectTypes a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves the representation of objects and classes of objects.";
    edu:partOf :ObjectRepresentation.
:OneDimensional a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves one spatial dimension.";
    edu:partOf :DimensionalAbstraction.
:OrderAbstraction a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves ordering or comparison concepts.";
    edu:partOf :AbstractionScope.
:Patternblocks a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Represents geometric shapes with a pattern block.";
    edu:partOf :PhysicalGeometry.
:PhysicalGeometry a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Represents geometric shapes with physical objects.";
    edu:partOf :GeometryRepresentation.
:PhysicalNumbers a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Represents numbers with physical objects.";
    edu:partOf :NumberRepresentation.
:PhysicalRuler a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves a physical ruler.";
    edu:integrates :CentimeterScale, :MillimeterScale;
    edu:partOf :LengthMeasurement.
:Protractor a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves a protractor.";
    edu:integrates :DegreeScale;
    edu:partOf :AngleMeasurement.
:QuantityMeasurement a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves the measurement of object quantities.";
    edu:partOf :MeasurementScope.
:RadianScale a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves radians to express the rotation of objects, oftentimes also used to express the phases of sinus and cosine functions. A radian is a multiple of pi, with 2 radian = 2 pi = 1 full circle and half a radian = 1/2 pi = a quarter circle.";
    edu:partOf :RotationAbstraction.
:RationalNumbers a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves numbers that can be expressed as a ratio of integers within the real numeric space.";
    edu:expands :IntegerNumbers;
    edu:partOf :RealNumbers.
:RealNumbers a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves numbers within the real numeric space.";
    edu:partOf :NumericSpace.
:RepresentationalScope a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves a form of representation such as geometric shapes or numbers.".
:Right a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves relative horizontal orientation situated at the right side position or direction than a reference point.";
    edu:partOf :SpatialDirection.
:RodNumerals a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Represents numbers with rod numerals.";
    edu:partOf :Numerals;
    edu:translates :Base10.
:Rollable a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves the physical property of objects that allows for continuous rotation or movement across a surface through a curved or rounded geometry.";
    edu:partOf :ShapeProperties.
:RomanNumerals a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Represents numbers with roman numerals.";
    edu:partOf :Numerals;
    edu:translates :Base10.
:RotationAbstraction a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves angles or angular concepts.";
    edu:partOf :AbstractionScope.
:SandClock a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves a sand clock.";
    edu:integrates :HourIntervals, :MinuteIntervals;
    edu:partOf :TimeMeasurement.
:ScatteredArrangement a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves the irregular positioning and non-uniform organization of objects.";
    edu:partOf :ObjectArrangement.
:SecondIntervals a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Time expressed in intervals of seconds.";
    edu:partOf :TimeIntervals.
:ShapeProperties a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves the physical property of objects that allows for the identification and differentiation of geometric forms through attributes such as edges, faces, and vertices to determine spatial behavior and mechanical constraints.";
    edu:partOf :MechanicalAbstraction.
:Solid a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves the identification and description of matter with a definite shape and volume (example: ice).";
    edu:partOf :StateProperties.
:South a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves the cardinal direction South.";
    edu:partOf :CardinalDirections.
:Southeast a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves the intercardinal direction Southeast.";
    edu:partOf :IntercardinalDirections.
:Southwest a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves the intercardinal direction Southwest.";
    edu:partOf :IntercardinalDirections.
:SpatialDirection a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves relative or cardinal orientation and movement indicators.";
    edu:partOf :DirectionalRepresentation.
:SpatialNumbers a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Represents numbers visually along a spatial dimension.";
    edu:partOf :NumberRepresentation.
:Stackable a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves the physical property of objects that allows for stable vertical arrangement or sequential layering.";
    edu:partOf :ShapeProperties.
:StateProperties a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves the identification and differentiation of states of matter.";
    edu:partOf :MechanicalAbstraction.
:Stopwatch a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves a stop watch.";
    edu:integrates :HourIntervals, :MillisecondIntervals, :MinuteIntervals, :SecondIntervals;
    edu:partOf :TimeMeasurement.
:SubtractiveCount a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Counts manifested objects by counting what's missing.";
    edu:inverts :AdditiveCount;
    edu:partOf :QuantityMeasurement.
:Sunclock a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves a sun clock.";
    edu:integrates :HourIntervals;
    edu:partOf :TimeMeasurement.
:Tangrams a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Represents geometric shapes with tangrams.";
    edu:partOf :PhysicalGeometry.
:Tapemeter a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves a tape meter.";
    edu:integrates :CentimeterScale, :MeterScale, :MillimeterScale;
    edu:partOf :LengthMeasurement.
:TemperatureAbstraction a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves temperature or thermal concepts.";
    edu:partOf :AbstractionScope.
:TemperatureMeasurement a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves temperature measurement.";
    edu:partOf :MeasurementScope.
:TemporalDirection a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves chronological or sequential orientation and progression indicators.";
    edu:partOf :DirectionalRepresentation.
:TenFrame a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves a ten frame: Typically a table with 2 rows and 5 columns where numbers are indicated by filled cells starting at the top left.";
    edu:partOf :VisualNumbers.
:Thermometer a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves a thermometer.";
    edu:integrates :CelsiusScale, :KelvinScale;
    edu:partOf :TemperatureMeasurement.
:ThreeDimensional a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves three spatial dimensions.";
    edu:expands :TwoDimensional;
    edu:partOf :DimensionalAbstraction.
:TimeAbstraction a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves time or duration concepts.";
    edu:partOf :AbstractionScope.
:TimeIntervals a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "The intervals used to measure time.";
    edu:partOf :TimeAbstraction.
:TimeMeasurement a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves time measurement.";
    edu:partOf :MeasurementScope.
:TonScale a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Weights measured in tons.";
    edu:partOf :WeightAbstraction.
:TriangleRuler a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves a triangle ruler.";
    edu:integrates :CentimeterScale, :DegreeScale, :MillimeterScale;
    edu:partOf :AngleMeasurement.
:TwoDimensional a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves two spatial dimensions.";
    edu:expands :OneDimensional;
    edu:partOf :DimensionalAbstraction.
:VectorObjects a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves graphic elements defined by geometric primitives such as circles, squares and stars.";
    edu:partOf :ObjectTypes.
:VisualGeometry a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Represents geometric shapes visually (yet not in as physical objects).";
    edu:partOf :GeometryRepresentation.
:VisualNumbers a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Represents numbers visually (yet not as physical objects nor as numerals).";
    edu:partOf :NumberRepresentation.
:VolumeAbstraction a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves volume or capacity concepts.";
    edu:partOf :AbstractionScope.
:VolumeMeasurement a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves volume measurement.";
    edu:partOf :MeasurementScope.
:WeekIntervals a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Time expressed as intervals of weeks.";
    edu:partOf :TimeIntervals.
:WeightAbstraction a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves mass or weight concepts.";
    edu:partOf :AbstractionScope.
:WeightMeasurement a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves weight measurement.";
    edu:partOf :MeasurementScope.
:West a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Involves the cardinal direction West.";
    edu:partOf :CardinalDirections.
:YearIntervals a owl:NamedIndividual, edu:Scope;
    rdfs:isDefinedBy "Time expressed in intervals of years.";
    edu:partOf :TimeIntervals.
