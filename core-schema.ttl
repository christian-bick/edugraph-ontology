#################################################################
#    Object Properties
#################################################################

###  http://edugraph.io/edu#expandedBy
edu:expandedBy rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf owl:topObjectProperty ;
               owl:inverseOf edu:expands ;
               rdfs:domain edu:CompetencyEntity ;
               rdfs:range edu:CompetencyEntity .


###  http://edugraph.io/edu#expands
edu:expands rdf:type owl:ObjectProperty ;
            rdfs:subPropertyOf owl:topObjectProperty ;
            rdfs:domain edu:CompetencyEntity ;
            rdfs:range edu:CompetencyEntity ;
            rdfs:isDefinedBy """A expands B when understanding A is based on an understanding of B.

For example: 

- Multiplication expands addition
- Fraction notation expands division""" .


###  http://edugraph.io/edu#hasPart
edu:hasPart rdf:type owl:ObjectProperty ;
            rdfs:subPropertyOf owl:topObjectProperty ;
            owl:inverseOf edu:partOf ;
            rdfs:domain owl:Thing ;
            rdfs:range owl:Thing .


###  http://edugraph.io/edu#integratedBy
edu:integratedBy rdf:type owl:ObjectProperty ;
                 rdfs:subPropertyOf owl:topObjectProperty ;
                 owl:inverseOf edu:integrates ;
                 rdfs:domain edu:CompetencyEntity ;
                 rdfs:range edu:CompetencyEntity .


###  http://edugraph.io/edu#integrates
edu:integrates rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf owl:topObjectProperty ;
               rdfs:domain edu:CompetencyEntity ;
               rdfs:range edu:CompetencyEntity ;
               rdfs:isDefinedBy """A integrates B when A is synthesized in parts using B.

For example: 

- Fraction addition integrates determining the smallest common denominator
- The Pythagorean theorem integrates the addition, exponation and root operations""" .


###  http://edugraph.io/edu#invertedBy
edu:invertedBy rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf edu:expandedBy ;
               owl:inverseOf edu:inverts ;
               rdfs:domain edu:CompetencyEntity ;
               rdfs:range edu:CompetencyEntity .


###  http://edugraph.io/edu#inverts
edu:inverts rdf:type owl:ObjectProperty ;
            rdfs:subPropertyOf edu:expands ;
            rdfs:domain edu:CompetencyEntity ;
            rdfs:range edu:CompetencyEntity ;
            rdfs:isDefinedBy """A inverts B when one is the logical inverse concept of the other. This relation is in theory symmetric but in practice oftentimes has a high likelyhood of one concept preceeding the other.

For example:

- Subtraction inverts addition
- Root inverts exponentiation""" .


###  http://edugraph.io/edu#involvedBy
edu:involvedBy rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf owl:topObjectProperty ;
               owl:inverseOf edu:involves ;
               rdfs:domain edu:CompetencyDescriptor ;
               rdfs:range edu:CompetencyEntity .


###  http://edugraph.io/edu#involves
edu:involves rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf owl:topObjectProperty ;
             rdfs:domain edu:CompetencyEntity ;
             rdfs:range edu:CompetencyDescriptor ;
             rdfs:isDefinedBy "When a competency entity involves a competency descriptor, it forms a more specialized competency entity that can be identified through that descriptor." .


###  http://edugraph.io/edu#partOf
edu:partOf rdf:type owl:ObjectProperty ;
           rdfs:subPropertyOf owl:topObjectProperty ;
           rdfs:domain owl:Thing ;
           rdfs:range owl:Thing ;
           rdfs:isDefinedBy "An entity that is part of another entity inherits its attributes and relations." .


###  http://edugraph.io/edu#translatedBy
edu:translatedBy rdf:type owl:ObjectProperty ;
                 rdfs:subPropertyOf edu:integratedBy ;
                 owl:inverseOf edu:translates ;
                 rdfs:domain edu:CompetencyEntity ;
                 rdfs:range edu:CompetencyEntity .


###  http://edugraph.io/edu#translates
edu:translates rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf edu:integrates ;
               rdfs:domain edu:CompetencyEntity ;
               rdfs:range edu:CompetencyEntity ;
               rdfs:isDefinedBy """A translates B when one is a representation of the other. This relation is in theory symmetric but in practice oftentimes has a high likelyhood of one representation preceeding the other.

For example:

- Fraction notation translates proportions
- Graphs translate functions""" .


#################################################################
#    Classes
#################################################################

###  http://edugraph.io/edu#Ability
edu:Ability rdf:type owl:Class ;
            rdfs:subClassOf edu:CompetencyDescriptor ;
            rdfs:isDefinedBy "A general mental attribute that is trainable and applicable across various fields." .


###  http://edugraph.io/edu#Area
edu:Area rdf:type owl:Class ;
         rdfs:subClassOf edu:CompetencyDescriptor ;
         rdfs:comment "A specific domain of knowledge and understanding within a field." .


###  http://edugraph.io/edu#CompetencyDescription
edu:CompetencyDescription rdf:type owl:Class ;
                          owl:equivalentClass [ rdf:type owl:Restriction ;
                                                owl:onProperty edu:involves ;
                                                owl:someValuesFrom edu:Ability
                                              ] ,
                                              [ rdf:type owl:Restriction ;
                                                owl:onProperty edu:involves ;
                                                owl:someValuesFrom edu:Area
                                              ] ,
                                              [ rdf:type owl:Restriction ;
                                                owl:onProperty edu:involves ;
                                                owl:someValuesFrom edu:Scope
                                              ] ;
                          rdfs:subClassOf edu:CompetencyEntity ;
                          rdfs:isDefinedBy "Describes a competency through the involved observable attributes." .


###  http://edugraph.io/edu#CompetencyDescriptor
edu:CompetencyDescriptor rdf:type owl:Class ;
                         rdfs:subClassOf edu:CompetencyEntity ;
                         rdfs:isDefinedBy "A significant and observable attribute to describe competencies." .


###  http://edugraph.io/edu#CompetencyEntity
edu:CompetencyEntity rdf:type owl:Class ;
                     rdfs:subClassOf owl:Thing ;
                     rdfs:isDefinedBy "An entity involved in the description and expression of competencies." .


###  http://edugraph.io/edu#Scope
edu:Scope rdf:type owl:Class ;
          rdfs:subClassOf edu:CompetencyDescriptor ;
          rdfs:comment "An observable context of learning that affects abstraction, variation, generalization, complexity and ultimately measurable differences in difficulty across various areas." .


